# Server
PORT=8080

# Database (Neon PostgreSQL)
DATABASE_URL=postgresql://username:password@your-neon-host.neon.tech/toolbox?sslmode=require

# File storage
UPLOAD_DIR=./uploads
GENERATED_DIR=./generated
MAX_UPLOAD_SIZE_MB=50

# Cleanup scheduler
CLEANUP_INTERVAL=10m
FILE_RETENTION=1h

# Currency service
FX_PROVIDER_URL=https://api.frankfurter.dev
FX_CACHE_TTL=30m
FX_STALE_WINDOW=6h
FX_WARMUP_EVERY=30m
FX_WARMUP_LIMIT=30
FX_HTTP_TIMEOUT=8s
# 12 months
FX_HISTORY_KEEP=8760h
